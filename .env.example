# --- Sentiment Analysis & Review Intelligence Platform Environment Variables ---

# Database connection URI (Defaults to SQLite for local development)
# For PostgreSQL: postgresql://username:password@localhost:5432/review_intel_db
DATABASE_URL=sqlite:///./sentiment_platform.db

# Cryptographic token signing secret (Should be a strong randomly generated string in production)
JWT_SECRET=4f2a7b8e9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f
JWT_ALGORITHM=HS256

# Duration for which user session tokens remain valid (in minutes, 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Folder to cache Hugging Face pipelines model weights locally
MODEL_CACHE_DIR=./model_cache

# Target models to fetch from Hugging Face repository hub
MODEL_SENTIMENT=lxyuan/distilbert-base-multilingual-cased-sentiments-student
MODEL_EMOTION=bhadresh-savani/distilbert-base-uncased-emotion
MODEL_SUMMARIZATION=t5-small
